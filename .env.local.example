# AI Relay - Environment Variables
# Copy this file to .env.local and fill in your values

# === Authentication ===
# Clients must send: Authorization: Bearer <RELAY_API_KEY>
# Comma-separated for multiple keys
RELAY_API_KEY=your-secret-key-here

# Separate Admin Key (optional, falls back to RELAY_API_KEY if not set)
# Comma-separated for multiple admin login keys
RELAY_ADMIN_KEY=your-admin-key-here

# Secret for signing temporary client keys (optional, fallback to admin/api key if not set)
RELAY_SIGNING_SECRET=your-signing-secret-here

# Secret for hashing device tokens (required for local relay device authentication)
# Generate with: openssl rand -hex 32
DEVICE_TOKEN_SECRET=your-device-token-secret-here


# === Provider API Keys ===
# Comma-separated for key rotation (round-robin)

# OpenAI
OPENAI_KEYS=sk-your-openai-key-1,sk-your-openai-key-2

# Anthropic (Claude)
CLAUDE_KEYS=sk-ant-your-claude-key-1

# DeepSeek
DEEPSEEK_KEYS=sk-your-deepseek-key-1

# Xiaomi (MiMo)
XIAOMI_KEYS=your-xiaomi-key-1

# === Optional: Custom Base URLs ===
# Uncomment and set if using a custom endpoint
# OPENAI_BASE_URL=https://api.openai.com
# CLAUDE_BASE_URL=https://api.anthropic.com
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# XIAOMI_BASE_URL=https://api.xiaomi.com

# === Vercel KV (auto-configured on Vercel, manual for local dev) ===
# Not needed on Cloudflare Pages — CF uses native KV + D1 bindings instead
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# === Cloudflare Pages (set in GitHub Secrets / CF Pages env vars) ===
# CRON_SECRET=your-secret     # Authenticates cron job requests on CF Pages

# === User-Agent Configuration ===
# Override the default User-Agent sent to upstream providers.
# Useful if a provider blocks the default SDK User-Agent strings.
# Note: Per-provider userAgent (set in Admin UI custom providers) takes precedence.
# RELAY_DEFAULT_USER_AGENT=Mozilla/5.0 (compatible; AIRelay/1.0)

# === Admin UI ===
# Minimum character length for provider API keys added via the Admin panel.
# Default is 20. Set to 0 to disable the length check entirely.
# RELAY_API_KEY_MIN_LENGTH=20
